{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/nge/node",
    "rootDir": "doc",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "importHelpers": false,
    "skipLibCheck": true,
    "paths": {}
  },
  "include": ["doc/compiler/**/*.ts", "doc/builders/**/*.ts", "doc/src/frontmatter.ts"],
  "exclude": ["**/*.spec.ts"]
}
