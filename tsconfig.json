{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "esModuleInterop": true,
    "strict": true,
    "strictNullChecks": true,
    "experimentalDecorators": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "resolveJsonModule": true,
    "target": "ES2022",
    "moduleDetection": "force",
    "paths": {
      "@cisstech/nge": ["projects/nge"],
      "@cisstech/nge/directives": ["projects/nge/directives"],
      "@cisstech/nge/doc": ["projects/nge/doc"],
      "@cisstech/nge/doc/ssr": ["projects/nge/doc/ssr"],
      "@cisstech/nge/elements": ["projects/nge/elements"],
      "@cisstech/nge/monaco": ["projects/nge/monaco"],
      "@cisstech/nge/pipes": ["projects/nge/pipes"],
      "@cisstech/nge/services": ["projects/nge/services"],
      "@cisstech/nge/markdown": ["projects/nge/markdown"],
      "@cisstech/nge/markdown/shiki": ["projects/nge/markdown/shiki"],
      "@cisstech/nge/markdown/stackblitz": ["projects/nge/markdown/stackblitz"],
      "@cisstech/nge/utils": ["projects/nge/utils"],
      "@cisstech/nge/ui/tree": ["projects/nge/ui/tree"],
      "@cisstech/nge/ui/list": ["projects/nge/ui/list"],
      "@cisstech/nge/ui/icon": ["projects/nge/ui/icon"],
      "@cisstech/nge/ui/dialog": ["projects/nge/ui/dialog"]
    },
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "strictTemplates": true,
    "strictInjectionParameters": true
  }
}
